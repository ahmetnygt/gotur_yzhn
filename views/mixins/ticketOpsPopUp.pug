if (permissions.includes("SALE_CREATE_OWN_BRANCH") && isOwnBranchStop == "true" || permissions.includes("SALE_CREATE_OTHER_BRANCH") && isOwnBranchStop == "false")
    .ticket-op.m
        p ERKEK SATIŞ
        i.fa-solid.fa-caret-right
        ul.ticket-op-buttons
            each rs in routeStops
                if rs
                    if rs.isRestricted
                        button.ticket-op-button.restricted(type="button" disabled data-route-order=(rs && rs.order != null ? rs.order : "")) #{rs.title}
                    else
                        button.ticket-op-button(type="button" data-gender="m" data-action="sell" data-route-stop=rs.title data-stop-id=rs.stopId data-route-order=(rs && rs.order != null ? rs.order : "")) #{rs.title}

-
    // DÜZELTME: Bu izin kontrolü "//!-" (Pug yorum satırı) ile devre dışı
    // bırakılmıştı; opsiyon süresi geçmiş seferler için de REZERVASYON
    // menüsü, iznin adı ("Opsiyon süresi geçmiş sefere rezervasyon yapabilir")
    // ne söylese de HERKESE gösteriliyordu. Opsiyon tarihi geçmemişse ya da
    // kullanıcının PAST_TRIP_RESERVATION izni varsa menü gösterilir.
    var reservationDateValue = reservationOptionDate ? new Date(String(reservationOptionDate).replace("Z", "")) : null;
    var reservationOptionExpired = reservationDateValue && !Number.isNaN(reservationDateValue.getTime()) && reservationDateValue < new Date();
if !reservationOptionExpired || permissions.includes("PAST_TRIP_RESERVATION")
    .ticket-op.m
        p ERKEK REZERVASYON
        i.fa-solid.fa-caret-right
        ul.ticket-op-buttons
            each rs in routeStops
                if rs
