                        button.ticket-op-button.restricted(type="button" disabled data-route-order=(rs && rs.order != null ? rs.order : "")) #{rs.title}
                    else
                        button.ticket-op-button(type="button" data-gender="m" data-action="reservation" data-route-stop=rs.title data-stop-id=rs.stopId data-route-order=(rs && rs.order != null ? rs.order : "")) #{rs.title}
